  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The Power-to-Methanol process requires CO2 captured from the amine scrubbing
    unit and H2 produced by the electrolyzer to be combined and pressurized before
    entering the reactor. \n\nThe compressor block raises the pressure of this mixed
    feed stream to the reactor operating range of 40\u2013100 bar, as methanol synthesis
    over the Cu/ZnO/Al2O3 catalyst requires high pressure to achieve meaningful conversion.\n\nIn
    addition to feed compression, the compressor block also handles the recycle stream,
    unreacted gases recovered from the separation stage are recompressed and mixed
    back into the fresh feed, improving overall process efficiency and reducing feedstock
    waste."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
